{
  "info": {
    "name": "MagicRain API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"token\", pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "USERS",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "NODES",
      "item": [
        {
          "name": "Get All Nodes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/nodes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Node By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/nodes/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "nodes", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Node",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/nodes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nodo Norte 01\",\n  \"zone\": \"Zona Norte\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Node",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/nodes/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "nodes", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nodo Norte 01\",\n  \"zone\": \"Zona Norte\",\n  \"status\": \"active\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Node",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/nodes/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "nodes", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "READINGS",
      "item": [
        {
          "name": "Get Latest Reading",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/readings/latest",
            "header": []
          }
        },
        {
          "name": "Get All Readings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/readings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Reading By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/readings/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "readings", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Reading",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/readings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"temperature\": 22.5,\n  \"humidity\": 65,\n  \"pressure\": 760,\n  \"rainfall\": false,\n  \"condition\": \"sun\",\n  \"nodeId\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Reading",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/readings/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "readings", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"temperature\": 20.0,\n  \"humidity\": 70,\n  \"pressure\": 755,\n  \"rainfall\": true,\n  \"condition\": \"rain\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Reading",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/readings/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "readings", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
